{
  "trigger_phrases": {
    "implementation_mode": [
      "yert",
      "IMPLEMENT"
    ],
    "discussion_mode": [
      "SILENCE",
      "STOP",
      "DISCUSS",
      "TALK"
    ],
    "task_creation": [
      "mek:",
      "TASK",
      "TODO"
    ],
    "task_startup": [
      "start^",
      "START"
    ],
    "task_completion": [
      "finito",
      "FINISH"
    ],
    "context_compaction": [
      "squish",
      "COMPACT"
    ]
  },
  "git_preferences": {
    "add_pattern": "all",
    "default_branch": "develop",
    "commit_style": "detailed",
    "auto_merge": true,
    "auto_push": true,
    "has_submodules": false
  },
  "environment": {
    "os": "linux",
    "shell": "zsh",
    "developer_name": "skogix"
  },
  "blocked_actions": {
    "implementation_only_tools": [
      "Edit",
      "Write",
      "MultiEdit",
      "NotebookEdit"
    ],
    "bash_read_patterns": [],
    "bash_write_patterns": [],
    "extrasafe": false
  },
  "features": {
    "branch_enforcement": true,
    "task_detection": true,
    "auto_ultrathink": true,
    "icon_style": "nerd_fonts",
    "context_warnings": {
      "warn_85": true,
      "warn_90": true
    }
  }
}