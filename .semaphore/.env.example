# Semaphore Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to git - it contains sensitive information

# Admin credentials
SEMAPHORE_ADMIN=skogix
SEMAPHORE_ADMIN_PASSWORD=your_secure_password_here
SEMAPHORE_ADMIN_NAME=skogix
SEMAPHORE_ADMIN_EMAIL=your@email.com

# Web configuration
SEMAPHORE_WEB_ROOT=https://semaphore.skogai.se
