# Ansible Configuration Environment Variables
# Copy this file to .env and fill in your values

# Ansible vault password file (plaintext file containing the vault password)
# This is used to decrypt vault-encrypted files
ANSIBLE_VAULT_PASSWORD_FILE="${HOME}/.ssh/ansible-vault-password"

# Ansible become password file (can be plaintext or vault-encrypted)
# This is used for privilege escalation (sudo)
ANSIBLE_BECOME_PASSWORD_FILE="${HOME}/.ssh/ansible-become-password"

# Optional: Override default paths if your setup is different
# ANSIBLE_CONFIG="${HOME}/.ansible/ansible.cfg"
# ANSIBLE_INVENTORY="${HOME}/.ansible/.hosts"
