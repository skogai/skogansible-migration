# General Configuration
SKOGAI_DEBUG_LEVEL="INFO"
SKOGAI_HOME="$HOME/skogai"
SKOGAI_CORE="$SKOGAI_HOME/core"
SKOGAI_SRC="$SKOGAI_HOME/src"
SKOGAI_PROJECT="SkogAI"
SKOGAI_PROJECT_HOME="SkogAI"
SKOGAI_AICHAT_HOME="$SKOGAI_CORE/aichat"
SKOGAI_AIDER_HOME="$SKOGAI_CORE/aider"
SKOGAI_MEMORY_FILE="$SKOGAI_CORE/.skogai/memory.json"
SKOGAI_MODEL_LARGE="llama3.1"
SKOGAI_MODEL_SMALL="llama3.2"
SKOGAI_INSTALL_DIR="$HOME/skogai/core/bin"
SKOGAI_SCRIPTS="$SKOGAI_CORE/scripts"
