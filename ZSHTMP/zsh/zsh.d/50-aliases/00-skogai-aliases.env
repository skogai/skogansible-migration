alias zshrc="cd $SKOGAI_HOME/zsh.d/; nvim ."
alias aliasrc="cd $SKOGAI_HOME/zsh.d; nvim 50-aliases/00-skogai-aliases.env"
alias skog='cd $(git rev-parse --show-toplevel) && aider --dark-mode --config $SKOGAI_AIDER_HOME/aider.yml'
alias aider='aider --dark-mode'
alias aichatrc="cd $SKOGAI_CORE/aichat; nvim config.yaml"
alias dump='echo "$@"'
alias memory="aichat --role memory -- remember this: ' \$1"
