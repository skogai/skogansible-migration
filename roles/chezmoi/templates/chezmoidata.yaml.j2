# .chezmoidata.yaml - Managed by Ansible
# DO NOT EDIT MANUALLY - Changes will be overwritten
# Generated by ansible role: chezmoi
# Last updated: {{ ansible_date_time.iso8601 }}

# ==============================================================================
# MACHINE PROFILE
# ==============================================================================
machine:
  type: {{ chezmoi_machine_type }}
  hostname: {{ chezmoi_hostname }}

# ==============================================================================
# USER INFORMATION
# ==============================================================================
user:
  name: {{ chezmoi_user_name | quote }}
  email: {{ chezmoi_user_email | quote }}
  github_user: {{ chezmoi_github_user | quote }}

# ==============================================================================
# ENVIRONMENT FLAGS
# ==============================================================================
environment:
  personal: {{ chezmoi_personal | default(true) | lower }}
  work: {{ chezmoi_work | default(false) | lower }}
  headless: {{ chezmoi_headless | default(false) | lower }}
  gui: {{ chezmoi_gui | default(true) | lower }}

# ==============================================================================
# DESKTOP ENVIRONMENT
# ==============================================================================
desktop:
  window_manager: {{ chezmoi_wm | default('i3') }}
  laptop_mode: {{ chezmoi_laptop_mode | default(false) | lower }}
  terminal: {{ chezmoi_terminal | default('kitty') }}

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
features:
  ai_tools: {{ chezmoi_ai_tools | default(true) | lower }}
  development: {{ chezmoi_development | default(true) | lower }}

  gui_apps:
    enabled: {{ chezmoi_gui_apps_enabled | default(true) | lower }}
    dunst: {{ chezmoi_dunst_enabled | default(true) | lower }}
    kitty: {{ chezmoi_kitty_enabled | default(true) | lower }}

  dev_tools:
    direnv: {{ chezmoi_direnv_enabled | default(true) | lower }}
    gh: {{ chezmoi_gh_enabled | default(true) | lower }}
    gita: {{ chezmoi_gita_enabled | default(true) | lower }}

# ==============================================================================
# SKOGAI AGENT CONFIGURATIONS
# ==============================================================================
agents:
  claude:
    enabled: {{ chezmoi_agents.claude | default(true) | lower }}
  letta:
    enabled: {{ chezmoi_agents.letta | default(true) | lower }}
  amy:
    enabled: {{ chezmoi_agents.amy | default(true) | lower }}
  goose:
    enabled: {{ chezmoi_agents.goose | default(true) | lower }}
  dot:
    enabled: {{ chezmoi_agents.dot | default(true) | lower }}

# ==============================================================================
# ENVIRONMENT-SPECIFIC SETTINGS
# ==============================================================================
environments:
  development:
    debug: {{ chezmoi_debug | default(true) | lower }}
  production:
    debug: false

# ==============================================================================
# SKOGAI PATHS
# ==============================================================================
{% if chezmoi_skogai_home is defined %}
skogai_home: {{ chezmoi_skogai_home }}
skogai_docs: {{ chezmoi_skogai_docs }}
skogai_tools: {{ chezmoi_skogai_tools }}
{% endif %}
