#!/usr/bin/env bash
# {{ ansible_managed }}
# Example pre-commit hook
#
# This is a simple example hook that checks for common issues before committing.
# Customize this file to add your own checks.

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo -e "${GREEN}Running pre-commit checks...${NC}"

# Check for trailing whitespace
if git diff --cached --check --diff-filter=ACMR ; then
    echo -e "${GREEN}✓ No trailing whitespace${NC}"
else
    echo -e "${RED}✗ Found trailing whitespace${NC}"
    echo -e "${YELLOW}Fix with: git diff --cached --check${NC}"
    exit 1
fi

# Check for debug statements (example - customize for your languages)
FILES=$(git diff --cached --name-only --diff-filter=ACMR)
if echo "$FILES" | grep -qE '\.(py|js|ts|sh|bash)$'; then
    if git diff --cached | grep -E '^\+.*(console\.log|debugger|pdb\.set_trace|binding\.pry)'; then
        echo -e "${YELLOW}⚠ Warning: Found debug statements (console.log, debugger, pdb, etc.)${NC}"
        echo -e "${YELLOW}Consider removing them before committing${NC}"
        # Uncomment to make this blocking:
        # exit 1
    fi
fi

echo -e "${GREEN}✓ All pre-commit checks passed${NC}"
exit 0
