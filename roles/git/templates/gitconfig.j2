# {{ ansible_managed }}
# Global Git Configuration
# Generated by Ansible

[user]
{% if git_user_name | length > 0 %}
    name = {{ git_user_name }}
{% endif %}
{% if git_user_email | length > 0 %}
    email = {{ git_user_email }}
{% endif %}
{% if git_gpg_key_id | length > 0 or git_ssh_signing_key | length > 0 %}
    signingKey = {{ git_gpg_key_id if git_gpg_key_id | length > 0 else git_ssh_signing_key }}
{% endif %}

[init]
{% if git_default_branch | length > 0 %}
    defaultBranch = {{ git_default_branch }}
{% endif %}
{% if git_hooks_template_dir is defined %}
    templateDir = {{ ansible_facts['env']['HOME'] }}/.git-templates
{% endif %}

{% if git_safe_directories is defined and git_safe_directories | length > 0 %}
[safe]
{% for dir in git_safe_directories %}
    directory = {{ dir }}
{% endfor %}
{% endif %}

[core]
    editor = {{ git_core_editor }}
{% if git_core_pager is defined and git_core_pager | length > 0 %}
    pager = {{ git_core_pager }}
{% endif %}
    autocrlf = {{ git_core_autocrlf }}
    fileMode = {{ git_core_filemode | string | lower }}
    ignoreCase = {{ git_core_ignorecase | string | lower }}
{% if git_deploy_global_gitignore %}
    excludesFile = {{ git_global_gitignore_file }}
{% endif %}
{% if git_fsmonitor_enabled %}
    fsmonitor = true
{% endif %}

[color]
    ui = {{ git_color_ui }}

[push]
    default = {{ git_push_default }}
    followTags = {{ git_push_followTags | string | lower }}
    autoSetupRemote = {{ git_push_autoSetupRemote | string | lower }}

[pull]
    rebase = {{ git_pull_rebase | string | lower }}
    ff = {{ git_pull_ff }}

[merge]
    ff = {{ git_merge_ff }}
    conflictStyle = {{ git_merge_conflictstyle }}

[diff]
    algorithm = {{ git_diff_algorithm }}
    colorMoved = {{ git_diff_colorMoved }}
{% if git_diff_mnemonicPrefix is defined %}
    mnemonicPrefix = {{ git_diff_mnemonicPrefix | string | lower }}
{% endif %}

[rebase]
    autoSquash = {{ git_rebase_autosquash | string | lower }}
    autoStash = {{ git_rebase_autostash | string | lower }}

[fetch]
    prune = {{ git_fetch_prune | string | lower }}
    pruneTags = {{ git_fetch_pruneTags | string | lower }}

[rerere]
    enabled = {{ git_rerere_enabled | string | lower }}
    autoUpdate = {{ git_rerere_autoupdate | string | lower }}

[submodule]
    recurse = {{ git_submodule_recurse | string | lower }}

{% if git_column_ui is defined %}
[column]
    ui = {{ git_column_ui }}
{% endif %}

{% if git_branch_sort is defined %}
[branch]
    sort = {{ git_branch_sort }}
{% endif %}

[pack]
    threads = {{ git_pack_threads }}
{% if git_pack_windowMemory != "0" %}
    windowMemory = {{ git_pack_windowMemory }}
{% endif %}

{% if git_configure_credentials %}
{% if git_credential_helpers is defined and git_credential_helpers | length > 0 %}
{% for cred_helper in git_credential_helpers %}
[credential "{{ cred_helper.url }}"]
    helper =
    helper = {{ cred_helper.helper }}
{% endfor %}
{% endif %}
{% if git_credential_helper is defined %}
[credential]
{% if git_credential_helper == "cache" %}
    helper = cache --timeout={{ git_credential_cache_timeout }}
{% elif git_credential_helper == "store" %}
    helper = store --file={{ git_credential_store_file }}
{% else %}
    helper = {{ git_credential_helper }}
{% endif %}
{% endif %}
{% endif %}

{% if git_gpg_sign_commits or git_ssh_sign_commits %}
[commit]
    gpgSign = true
{% if git_commit_verbose is defined %}
    verbose = {{ git_commit_verbose | string | lower }}
{% endif %}
{% endif %}

{% if git_gpg_sign_tags or git_ssh_sign_tags %}
[tag]
    gpgSign = true
{% if git_tag_forceSignAnnotated is defined %}
    forceSignAnnotated = {{ git_tag_forceSignAnnotated | string | lower }}
{% endif %}
{% if git_tag_sort is defined %}
    sort = {{ git_tag_sort }}
{% endif %}
{% endif %}

{% if git_ssh_sign_commits or git_ssh_sign_tags %}
[gpg]
    format = ssh
{% if git_gpg_ssh_program is defined and git_gpg_ssh_program | length > 0 %}
[gpg "ssh"]
    program = {{ git_gpg_ssh_program }}
{% endif %}
{% endif %}

{% if git_deploy_aliases and git_aliases is defined %}
[alias]
{% for alias_name, alias_cmd in git_aliases.items() %}
    {{ alias_name }} = {{ alias_cmd }}
{% endfor %}
{% endif %}

{% if git_include_configs and git_config_includes is defined %}
# Include additional config files
{% for include_item in git_config_includes %}
[includeIf "{{ include_item.condition | default('') }}"]
    path = {{ include_item.path }}
{% endfor %}
{% endif %}
