# .zshrc - ZSH Configuration
# Generated by Ansible - Role: zsh
# Machine: {{ ansible_hostname }}
# Date: {{ ansible_date_time.date }}

# =============================================================================
# ZSH Configuration Loader
# =============================================================================
# All configuration is modular and loaded from {{ zsh_config_dir }}
# Configuration modules are organized by number:
#   00-path         - PATH and directory setup
#   10-settings     - Shell options, history, keybindings
#   20-functions    - Custom shell functions
#   30-aliases      - Command aliases
#   40-completions  - Completion system setup
#   50-secrets      - API keys and tokens (gitignored)
#   60-exports      - Environment variable exports
#   90-skogai       - SkogAI integration

# Source the modular configuration loader
if [[ -f {{ zsh_config_dir }}/loader.zsh ]]; then
    source {{ zsh_config_dir }}/loader.zsh
else
    echo "Warning: ZSH configuration loader not found at {{ zsh_config_dir }}/loader.zsh"
fi

# =============================================================================
# Local Customizations
# =============================================================================
# Source local customizations if present (not managed by ansible)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# =============================================================================
# Managed by Ansible
# =============================================================================
# To modify this configuration:
# 1. Edit vars/zsh.yml in the ansible repository
# 2. Run: ./run.sh --tags zsh
# 3. Or manually edit {{ zsh_config_dir }}/*.zsh files
